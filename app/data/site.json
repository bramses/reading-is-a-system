      "id": "you-won-t-remember-everything-you-read",
      "title": "You Won't Remember Everything You Read",
      "subtitle": "Make a Lookup Table to store and search for information you want to remember.",
      "tags": ["comprehension", "bad-habits"],
      "pairedWithIds": [],
